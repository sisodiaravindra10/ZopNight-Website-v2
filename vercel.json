    { "source": "/solutions/engineering", "destination": "/solutions/devops",        "permanent": false },
    { "source": "/solutions/engineering.html", "destination": "/solutions/devops",   "permanent": false },
    { "source": "/solutions/platform",    "destination": "/platform-engineering-hub","permanent": false },
    { "source": "/solutions/platform.html","destination":"/platform-engineering-hub","permanent": false },
    { "source": "/solutions/kubernetes-cost", "destination": "/solutions/kubernetes","permanent": false },
    { "source": "/solutions/kubernetes-cost.html", "destination": "/solutions/kubernetes", "permanent": false },
