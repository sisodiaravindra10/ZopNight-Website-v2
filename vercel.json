{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|svg|woff2?|ttf|otf|eot|png|jpg|jpeg|gif|webp|avif|ico)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/product/zopnight",      "destination": "/product/zopnight/atlas",  "permanent": false },
    { "source": "/product/zopnight.html", "destination": "/product/zopnight/atlas",  "permanent": false },
    { "source": "/product/zopday",        "destination": "/product",                 "permanent": false },
    { "source": "/product/zopday.html",   "destination": "/product",                 "permanent": false },
    { "source": "/product/zopday/:slug*", "destination": "/product",                 "permanent": false },
    { "source": "/product/zopcloud",      "destination": "/product",                 "permanent": false },
    { "source": "/product/zopcloud.html", "destination": "/product",                 "permanent": false },
    { "source": "/product/ai.html",       "destination": "/product",                 "permanent": false },
    { "source": "/product/ai",            "destination": "/product",                 "permanent": false },
    { "source": "/product/mcp-server",    "destination": "/developers/mcp",          "permanent": false },
    { "source": "/product/mcp-server.html","destination": "/developers/mcp",         "permanent": false },

    { "source": "/customers/:slug*",      "destination": "/customers",               "permanent": false },

    { "source": "/solutions/azure",       "destination": "/solutions/aws",           "permanent": false },
    { "source": "/solutions/azure.html",  "destination": "/solutions/aws",           "permanent": false },
    { "source": "/solutions/gcp",         "destination": "/solutions/aws",           "permanent": false },
    { "source": "/solutions/gcp.html",    "destination": "/solutions/aws",           "permanent": false },
    { "source": "/solutions/oci",         "destination": "/solutions/aws",           "permanent": false },
